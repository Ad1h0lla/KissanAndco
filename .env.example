 # GEMINI_API_KEY: Required for Gemini AI API calls.
 # Set this in your local environment or CI secrets. Do NOT commit real keys.
 GEMINI_API_KEY="your_gemini_api_key_here"

 # APP_URL: The URL where this app is hosted (used for callbacks / links).
 APP_URL="http://localhost:5173"

 # Weather API key (WeatherAPI.com) - used by the server to fetch forecasts.
 # Replace with your key when running locally.
 WEATHER_API_KEY="your_weatherapi_key_here"

 # Optional: OpenWeather key if you switch providers
 OPENWEATHER_API_KEY=
